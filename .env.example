# -----------------------------------------------------------------------------
# Next.js Brazilian Starter
# Arquivo de exemplo para variáveis de ambiente.
#
# Como usar:
# 1. Copie este arquivo para .env.local
# 2. Preencha os valores necessários para o seu projeto
# 3. Nunca publique .env.local, chaves privadas ou tokens reais no GitHub
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development

NEXT_PUBLIC_APP_NAME="Next.js Brazilian Starter"
NEXT_PUBLIC_APP_DESCRIPTION="Starter Next.js com arquitetura, UI, providers, contexts, dashboard, auth e utilitários brasileiros."
NEXT_PUBLIC_APP_LOCALE="pt-BR"
NEXT_PUBLIC_APP_TIMEZONE="America/Sao_Paulo"

# URL local durante o desenvolvimento
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# URL pública em produção
# Exemplo: https://seu-dominio.com.br
NEXT_PUBLIC_SITE_URL=""

# Repositório público do projeto
NEXT_PUBLIC_GITHUB_URL="https://github.com/seu-usuario/nextjs-brazilian-starter"


# -----------------------------------------------------------------------------
# Ambiente / Deploy
# -----------------------------------------------------------------------------
# Use para diferenciar ambientes quando necessário:
# development | staging | production
NEXT_PUBLIC_APP_ENV="development"

# URL gerada automaticamente pela Vercel, quando o projeto estiver hospedado lá.
# Normalmente não precisa preencher manualmente.
VERCEL_URL=""


# -----------------------------------------------------------------------------
# Banco de dados local ou externo
# -----------------------------------------------------------------------------
# Use DATABASE_URL se o projeto for usar Prisma, Drizzle, Postgres, SQLite,
# Neon, Railway, Supabase via conexão direta ou outro banco.
#
# Exemplos:
# PostgreSQL: postgresql://user:password@localhost:5432/database
# SQLite: file:./dev.db
DATABASE_URL=""

# Algumas plataformas usam DIRECT_URL para migrations/conexão direta.
DIRECT_URL=""


# -----------------------------------------------------------------------------
# Supabase opcional
# -----------------------------------------------------------------------------
# Preencha apenas se o projeto usar Supabase.
# A anon key pode ser pública, mas a service role key é privada.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""


# -----------------------------------------------------------------------------
# Autenticação / Sessão
# -----------------------------------------------------------------------------
# Use uma chave forte em produção.
# Você pode gerar com: openssl rand -base64 32
SESSION_SECRET=""
JWT_SECRET=""

# Caso adapte o projeto para NextAuth/Auth.js, mantenha essas variáveis.
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Provedores sociais opcionais
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""


# -----------------------------------------------------------------------------
# API interna / Webhooks / Segurança
# -----------------------------------------------------------------------------
# Chaves usadas para proteger rotas internas, webhooks, jobs e integrações.
API_SECRET_KEY=""
WEBHOOK_SECRET=""
CRON_SECRET=""

# URL base de uma API externa, caso seu frontend consuma backend separado.
NEXT_PUBLIC_API_URL=""


# -----------------------------------------------------------------------------
# E-mail opcional
# -----------------------------------------------------------------------------
# Use se o projeto tiver envio de e-mail transacional.
# Exemplos: Resend, SendGrid, Brevo, SMTP próprio etc.
EMAIL_FROM=""
RESEND_API_KEY=""
SENDGRID_API_KEY=""

SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE="false"


# -----------------------------------------------------------------------------
# Uploads / Storage opcional
# -----------------------------------------------------------------------------
# Use caso o projeto tenha upload de arquivos, imagens ou anexos.
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB="10"

STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_ENDPOINT=""


# -----------------------------------------------------------------------------
# Analytics / Monitoramento opcional
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""
SENTRY_DSN=""


# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# Variáveis públicas precisam começar com NEXT_PUBLIC_.
# Use true/false como texto e converta no código quando necessário.
NEXT_PUBLIC_ENABLE_QUERY_DEVTOOLS="true"
NEXT_PUBLIC_ENABLE_MAINTENANCE_MODE="false"
NEXT_PUBLIC_ENABLE_PUBLIC_REGISTER="true"
NEXT_PUBLIC_ENABLE_DASHBOARD_PREVIEW="true"


# -----------------------------------------------------------------------------
# Debug
# -----------------------------------------------------------------------------
DEBUG="false"
LOG_LEVEL="info"
